---
x-common-config: &common-config
  logging:
    driver: "json-file"
    options:
      max-size: "10m"
      max-file: "3"
  deploy:
    resources:
      limits:
        cpus: 1.0
        memory: 1G
      reservations:
        memory: 512M

services:
  search-permissions:
    image: busybox:latest
    volumes:
      - /search:/data
    command: chown -R 1000:1000 /data
    restart: "no"
    labels:
      com.bluespice.service: "search-permissions"
      com.bluespice.type: "init"

  search:
    image: /search:
    container_name: bluespice-search
    restart: unless-stopped
    networks:
      - bluespice-network
    volumes:
      - /search:/usr/share/opensearch/data
    environment:
      - discovery.type=single-node
      - bootstrap.memory_lock=true
      - "OPENSEARCH_JAVA_OPTS=-Xms512m -Xmx512m"
      - "OPENSEARCH_PATH_CONF=/usr/share/opensearch/config"
      # Disk watermarks to avoid runaway disk usage
      - "cluster.routing.allocation.disk.watermark.low=80%"
      - "cluster.routing.allocation.disk.watermark.high=85%"
      - "cluster.routing.allocation.disk.watermark.flood_stage=90%"
      - "cluster.info.update.interval=5m"
    ulimits:
      memlock:
        soft: -1
        hard: -1
      nofile:
        soft: 65536
        hard: 65536
    healthcheck:
      test: curl -f http://localhost:9200 || exit 1
      start_period: 90s
      interval: 30s
      timeout: 10s
      retries: 10
    depends_on:
      search-permissions:
        condition: service_completed_successfully
    <<: *common-config
    deploy:
      resources:
        limits:
          # Tighter memory cap for this host (was 1.5G)
          memory: 1.25G
        reservations:
          memory: 512M
    labels:
      com.bluespice.service: "search"
      com.bluespice.type: "persistent-data"

  database-permissions:
    image: busybox:latest
    volumes:
      - /database:/data
    command: sh -c "chown -R 911:911 /data && chmod -R 755 /data"
    restart: "no"
    labels:
      com.bluespice.service: "database-permissions"
      com.bluespice.type: "init"

  database:
    image: /database:
    container_name: bluespice-database
    restart: unless-stopped
    networks:
      - bluespice-network
    volumes:
      - /database/logs:/config/log/mysql
      - /database/data:/config/databases
      - ./mariadb-custom.cnf:/config/custom.cnf:ro
    environment:
      - MYSQL_ROOT_PASSWORD=
      - MYSQL_RANDOM_ROOT_PASSWORD=no
      - MYSQL_ALLOW_EMPTY_PASSWORD=no
      - MYSQL_INITDB_SKIP_TZINFO=1
      - TZ=UTC
    healthcheck:
      test: ["CMD", "nc", "-z", "localhost", "3306"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 60s
    depends_on:
      database-permissions:
        condition: service_completed_successfully
    <<: *common-config
    labels:
      com.bluespice.service: "database"
      com.bluespice.type: "persistent-data"

  cache:
    image: /cache:
    container_name: bluespice-cache
    restart: unless-stopped
    networks:
      - bluespice-network
    healthcheck:
      test: echo stats | nc localhost 11211 || exit 1
      start_period: 10s
      interval: 30s
      timeout: 10s
      retries: 3
    <<: *common-config
    labels:
      com.bluespice.service: "cache"
      com.bluespice.type: "persistent-data"

networks:
  bluespice-network:
    external: true
