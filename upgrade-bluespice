#!/bin/bash
# BlueSpice Multi-Wiki Upgrade Script
# Upgrades all wikis (and optionally shared infrastructure) to a new BlueSpice version.
#
# Key design decisions:
#   - No global set -euo pipefail; each step is checked individually
#   - Strict mode from docker-utils.sh is explicitly reset after sourcing
#   - OAuth extension presence is checked on the HOST volume before container recreation
#   - update.php is run directly via docker exec (not via bluespice-deploy-wiki)
#   - Each wiki is upgraded independently; failure of one does not stop others
#   - Required env vars (CACHE_HOST etc.) are verified/added to compose files before upgrade

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
WIKIS_DIR="$(dirname "$SCRIPT_DIR")/wikis"
SHARED_DIR="${SCRIPT_DIR}/shared"
BACKUP_DIR="/tmp/bluespice-upgrade-$(date +%Y%m%d-%H%M%S)"

# Source libraries, then immediately reset any strict mode they may have set
for lib in logging.sh docker-utils.sh oauth-config.sh gtag-config.sh semantic-extensions-config.sh upstream-check.sh; do
    lib_path="${SCRIPT_DIR}/lib/${lib}"
    if [[ ! -f "$lib_path" ]]; then
        echo "Error: Required library not found: $lib_path" >&2
        exit 1
    fi
    # shellcheck source=/dev/null
    source "$lib_path"
done
# docker-utils.sh has `set -euo pipefail` — reset it so it does not affect this script
set +e; set +u; set +o pipefail 2>/dev/null || true

# ============================================================
# Argument parsing
# ============================================================
TARGET_VERSION=""
FORCE=false
SPECIFIC_WIKI=""
SKIP_SHARED=false
DRY_RUN=false

usage() {
    cat <<USAGE
Usage: $0 [OPTIONS]

Upgrade BlueSpice wikis to a new version.

OPTIONS:
  -v, --version VERSION   Target version (default: auto-detect from Docker Hub)
  -f, --force             Re-run upgrade even if already on target version
  -w, --wiki WIKI_NAME    Upgrade only the named wiki (default: all)
  -s, --skip-shared       Skip shared services (DB, cache, proxy) upgrade
  -n, --dry-run           Show what would be done without making changes
  -h, --help              Show this help

EXAMPLES:
  $0                          # Auto-detect latest and upgrade all wikis
  $0 --version 5.2.2          # Upgrade all wikis to 5.2.2
  $0 --version 5.2.2 --wiki mywiki  # Upgrade only mywiki to 5.2.2
  $0 --skip-shared            # Upgrade wikis only, leave shared services alone
USAGE
    exit 1
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        -v|--version)     TARGET_VERSION="$2"; shift 2 ;;
        -f|--force)       FORCE=true; shift ;;
        -w|--wiki)        SPECIFIC_WIKI="$2"; shift 2 ;;
        -s|--skip-shared) SKIP_SHARED=true; shift ;;
        -n|--dry-run)     DRY_RUN=true; shift ;;
        -h|--help)        usage ;;
        *) log_error "Unknown option: $1"; usage ;;
    esac
done

# ============================================================
# Utility functions
# ============================================================

detect_latest_version() {
    local response
    response=$(curl -sf \
        "https://hub.docker.com/v2/repositories/bluespice/wiki/tags/?page_size=100&ordering=last_updated" \
        2>/dev/null) || {
        log_warn "Could not reach Docker Hub to detect latest version"
        return 1
    }
    local version
    version=$(echo "$response" \
        | grep -oP '"name":\s*"\K[0-9]+\.[0-9]+\.[0-9]+(?=")' \
        | sort -V | tail -1)
    if [[ -z "$version" ]]; then
        log_warn "Could not parse version from Docker Hub response"
        return 1
    fi
    echo "$version"
}

# Read a single value from a KEY=VALUE env file
read_env_var() {
    local file="$1"
    local var="$2"
    grep "^${var}=" "$file" 2>/dev/null | head -1 | cut -d'=' -f2- | tr -d '"' | tr -d "'"
}

# Ensure a VAR=VALUE line appears in BOTH service blocks of a docker-compose file.
# Inserts the line immediately before each `<<: *common-config` anchor if missing.
ensure_compose_env_var() {
    local compose_file="$1"
    local var_name="$2"
    local var_value="$3"

    # Count how many times this var appears (expect 2 — wiki-web and wiki-task)
    local count
    count=$(grep -c "^\s*- ${var_name}=" "$compose_file" 2>/dev/null || echo 0)

    if [[ "$count" -ge 2 ]]; then
        return 0  # Already present in both service blocks
    fi

    log_warn "    ${var_name} missing from $(basename "$compose_file") — adding..."

    if [[ "$DRY_RUN" == "true" ]]; then
        log_info "    [DRY RUN] Would add ${var_name}=${var_value}"
        return 0
    fi

    python3 - "$compose_file" "$var_name" "$var_value" << 'PYEOF'
import re, sys

compose_file, var_name, var_value = sys.argv[1], sys.argv[2], sys.argv[3]
var_line = f'      - {var_name}={var_value}\n'

with open(compose_file, 'r') as f:
    lines = f.readlines()

# Walk the file and insert var_line at the end of each `environment:` block.
# An environment block (4-space indent header) ends when we see a non-blank
# line that does NOT start with 6 spaces (i.e. the next top-level service key).
# This is safer than the old approach of inserting before <<: *common-config,
# which could appear after a volumes: block rather than environment:.
new_lines = []
in_environment = False
added = 0

for line in lines:
    stripped = line.rstrip('\n')

    if re.match(r'^    environment:\s*$', stripped):
        in_environment = True
        new_lines.append(line)
        continue

    if in_environment:
        # Still inside the block: 6-space-indented items or blank lines
        if re.match(r'^      ', stripped) or stripped == '':
            new_lines.append(line)
            continue
        else:
            # First line that belongs to the next block — insert here
            new_lines.append(var_line)
            added += 1
            in_environment = False

    new_lines.append(line)

# Handle environment block at end of file
if in_environment:
    new_lines.append(var_line)
    added += 1

if added == 0:
    print(f'WARNING: Could not find environment block for {var_name}', file=sys.stderr)
    sys.exit(1)

with open(compose_file, 'w') as f:
    f.writelines(new_lines)

print(f'Added {var_name} ({added} occurrence(s))')
PYEOF
    # shellcheck disable=SC2181
    if [[ $? -ne 0 ]]; then
        log_warn "    Could not auto-add ${var_name} — please add it manually to ${compose_file}"
    fi
}

# Ensure a volume mount appears in BOTH service blocks of a docker-compose file.
# host_path and container_path are the two sides of the mount.
ensure_compose_volume_mount() {
    local compose_file="$1"
    local host_path="$2"
    local container_path="$3"

    local search_str="${host_path}:${container_path}"
    local count
    count=$(grep -cF "$search_str" "$compose_file" 2>/dev/null | head -1 | tr -d "[:space:]"); count="${count:-0}"

    if [[ "$count" -ge 2 ]]; then
        return 0  # Already present in both service blocks
    fi

    log_warn "    Volume mount ${container_path} missing — adding..."

    if [[ "$DRY_RUN" == "true" ]]; then
        log_info "    [DRY RUN] Would add ${host_path}:${container_path}"
        return 0
    fi

    python3 - "$compose_file" "$host_path" "$container_path" << 'PYEOF2'
import sys

compose_file, host_path, container_path = sys.argv[1], sys.argv[2], sys.argv[3]
mount_line = f'      - {host_path}:{container_path}\n'

with open(compose_file, 'r') as f:
    lines = f.readlines()

# Insert mount_line at the end of each volumes: block (before next non-volume line)
new_lines = []
in_volumes = False
added = 0

for i, line in enumerate(lines):
    stripped = line.strip()
    if stripped == 'volumes:' and line.startswith('    '):
        in_volumes = True
        new_lines.append(line)
        continue
    if in_volumes:
        if stripped.startswith('- ') and line.startswith('      '):
            new_lines.append(line)
            # Check if next line is still a volume entry
            next_line = lines[i+1] if i+1 < len(lines) else ''
            if not (next_line.strip().startswith('- ') and next_line.startswith('      ')):
                if mount_line not in new_lines[-10:]:
                    new_lines.append(mount_line)
                    added += 1
                in_volumes = False
            continue
        else:
            in_volumes = False
    new_lines.append(line)

with open(compose_file, 'w') as f:
    f.writelines(new_lines)

print(f"Added {added} volume mount(s)")
PYEOF2
}

# Ensure a tmpfs entry appears in a service block of a docker-compose file.
# Usage: ensure_compose_tmpfs <compose_file> <tmpfs_entry> [service_name]
# If service_name is given, only that service is checked/modified.
ensure_compose_tmpfs() {
    local compose_file="$1"
    local tmpfs_entry="$2"
    local service_name="${3:-}"
    local service_label="${service_name:-all services}"

    # Let add_tmpfs.py handle idempotency — it exits cleanly if already present
    log_info "    Checking tmpfs ${tmpfs_entry} in ${service_label}..."

    if [[ "$DRY_RUN" == "true" ]]; then
        log_info "    [DRY RUN] Would ensure tmpfs: - ${tmpfs_entry} in ${service_label}"
        return 0
    fi

    local cmd_args=("${SCRIPT_DIR}/lib/add_tmpfs.py" "$compose_file" "$tmpfs_entry")
    if [[ -n "$service_name" ]]; then
        cmd_args+=(--service "$service_name")
    fi

    if ! python3 "${cmd_args[@]}"; then
        log_warn "    Could not auto-add tmpfs ${tmpfs_entry} to ${service_label} -- please add it manually to ${compose_file}"
    fi
}


# Fix PermissionManagerActivePreset when set to "custom" on Free edition wikis.
# Free edition only allows: public, protected, private.
fix_permission_manager_preset() {
    local db_name="$1"
    local db_user="$2"
    local db_pass="$3"

    log_info "  Checking PermissionManagerActivePreset..."

    local current_preset
    current_preset=$(docker exec bluespice-database \
        mariadb -u"${db_user}" -p"${db_pass}" "${db_name}" \
        -sNe "SELECT s_value FROM bs_settings3 WHERE s_name='PermissionManagerActivePreset' LIMIT 1;" \
        2>/dev/null | tr -d '"' || echo "")

    if [[ "$current_preset" == "custom" ]]; then
        log_warn "  PermissionManagerActivePreset='custom' is invalid for Free edition — resetting to 'public'"
        if [[ "$DRY_RUN" != "true" ]]; then
            if docker exec bluespice-database \
                mariadb -u"${db_user}" -p"${db_pass}" "${db_name}" \
                -e "UPDATE bs_settings3 SET s_value='\"public\"' WHERE s_name='PermissionManagerActivePreset';" \
                2>/dev/null; then
                log_info "  PermissionManagerActivePreset reset to 'public'"
            else
                log_warn "  Could not reset PermissionManagerActivePreset (non-fatal)"
            fi
        else
            log_info "  [DRY RUN] Would reset PermissionManagerActivePreset to 'public'"
        fi
    else
        log_info "  PermissionManagerActivePreset is OK (${current_preset:-not set})"
    fi
}

# Edit a post-init-settings file, falling back to docker exec if host permissions deny access.
# Usage: edit_post_init <wiki_name> <host_path> <command> [args...]
# <command> can be "sed", "append", or "grep-delete"
edit_post_init() {
    local wiki_name="$1"
    local host_path="$2"
    local cmd="$3"
    shift 3
    local container_path="/data/bluespice/post-init-settings.php"

    case "$cmd" in
        sed)
            # $1 = sed expression
            if ! sed -i "$1" "$host_path" 2>/dev/null; then
                local container_name
                container_name=$(get_container_name "$wiki_name") 2>/dev/null || return 1
                docker exec --user root "$container_name" sed -i "$1" "$container_path" 2>/dev/null || return 1
            fi
            ;;
        append)
            # $1 = text to append
            # Use subshell so bash's redirect-failure error is also suppressed
            if ! (printf '%s\n' "$1" >> "$host_path") 2>/dev/null; then
                local container_name
                container_name=$(get_container_name "$wiki_name") 2>/dev/null || return 1
                docker exec --user root "$container_name" sh -c "printf '%s\n' '$1' >> $container_path" 2>/dev/null || return 1
            fi
            ;;
    esac
}

# Bump wgCacheEpoch in post-init-settings.php to bust stale browser/server caches.
update_cache_epoch() {
    local wiki_name="$1"
    local post_init_file="$2"

    if [[ ! -f "$post_init_file" ]]; then
        return 0
    fi

    local epoch
    epoch=$(date +%Y%m%d%H%M%S)

    if [[ "$DRY_RUN" == "true" ]]; then
        log_info "  [DRY RUN] Would set wgCacheEpoch=$epoch in $(basename "$post_init_file")"
        return 0
    fi

    if grep -q 'wgCacheEpoch' "$post_init_file"; then
        edit_post_init "$wiki_name" "$post_init_file" sed "s/\\\$wgCacheEpoch = .*;/\$wgCacheEpoch = \"${epoch}\";/" \
            || log_warn "  Could not update wgCacheEpoch"
    else
        edit_post_init "$wiki_name" "$post_init_file" append "\$wgCacheEpoch = \"${epoch}\";" \
            || log_warn "  Could not append wgCacheEpoch"
    fi
    log_info "  Set wgCacheEpoch=$epoch in $(basename "$post_init_file")"
}

# Enable wire WebSocket URL for existing wikis that had it disabled.
# Previously we disabled this because the wire container wasn't deployed.
# Now that we deploy the wire container, we need to remove the override
# so the built-in $wgServer/_wire URL takes effect.
enable_wire_websocket_url() {
    local wiki_name="$1"
    local post_init_file="$2"

    if [[ ! -f "$post_init_file" ]]; then
        return 0
    fi

    if [[ "$DRY_RUN" == "true" ]]; then
        log_info "  [DRY RUN] Would re-enable mwsgWireServiceWebsocketUrl in $(basename "$post_init_file")"
        return 0
    fi

    if grep -q "mwsgWireServiceWebsocketUrl.*=.*''\|mwsgWireServiceWebsocketUrl.*=.*\"\"" "$post_init_file"; then
        log_info "  Removing mwsgWireServiceWebsocketUrl='' override (wire container now deployed)..."
        local patterns=(
            '/mwsgWireServiceWebsocketUrl/d'
            '/# Disable the wire WebSocket URL/d'
            '/# sets this to .wgServer\/_wire even when/d'
            '/# deployed. Without this override every/d'
            '/# loop that wastes PHP-FPM workers/d'
            '/# Wire WebSocket Service/d'
            '/# The bluespice\/wiki container always sets/d'
            '/# deployed. This causes every open browser/d'
            '/# loop .token generate.*HTTP request/d'
            '/# and CPU on all wikis. Override it/d'
            '/# wire service\./d'
        )
        for pat in "${patterns[@]}"; do
            edit_post_init "$wiki_name" "$post_init_file" sed "$pat" 2>/dev/null || true
        done
        log_info "  Re-enabled wire WebSocket URL in $(basename "$post_init_file")"
    else
        log_info "  Wire WebSocket URL not overridden in $(basename "$post_init_file") — OK"
    fi
}

# Ensure wgParserCacheType uses memcached in post-init-settings.php.
# The bluespice/wiki container sets wgParserCacheType = CACHE_NONE by default,
# forcing a full re-parse on every page view and post-save page load. Since
# memcached is always configured in these deployments, enabling the parser
# cache is safe and significantly reduces page load times. Idempotent.
fix_parser_cache() {
    local wiki_name="$1"
    local post_init_file="$2"

    if [[ ! -f "$post_init_file" ]]; then
        return 0
    fi

    if [[ "$DRY_RUN" == "true" ]]; then
        log_info "  [DRY RUN] Would enable parser cache in $(basename "$post_init_file")"
        return 0
    fi

    if grep -q "wgParserCacheType" "$post_init_file"; then
        log_info "  wgParserCacheType already set in $(basename "$post_init_file") — skipping"
        return 0
    fi

    # shellcheck disable=SC2016  # $GLOBALS is PHP code, not a shell variable
    local parser_cache_block='
# Enable parser cache using the already-configured memcached backend.
# The bluespice/wiki container sets wgParserCacheType = CACHE_NONE by default,
# forcing a full wikitext re-parse on every page view and post-save page load.
$GLOBALS['"'"'wgParserCacheType'"'"'] = CACHE_MEMCACHED;'

    edit_post_init "$wiki_name" "$post_init_file" append "$parser_cache_block" \
        || log_warn "  Could not append parser cache setting"
    log_info "  Enabled parser cache (CACHE_MEMCACHED) in $(basename "$post_init_file")"
}

# ============================================================
# Wiki upgrade
# ============================================================
upgrade_wiki() {
    local wiki_name="$1"
    local target_version="$2"

    local wiki_dir="${WIKIS_DIR}/${wiki_name}"
    local compose_file="${wiki_dir}/docker-compose.main.yml"
    local env_file="${wiki_dir}/.env"

    log_info ""
    log_info "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    log_info "Wiki: $wiki_name"
    log_info "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

    if [[ ! -f "$env_file" ]]; then
        log_error "  .env not found: $env_file"
        return 1
    fi
    if [[ ! -f "$compose_file" ]]; then
        log_error "  docker-compose.main.yml not found: $compose_file"
        return 1
    fi

    # Read wiki settings from its own .env (not shared env)
    local current_version edition data_dir db_name db_user db_pass
    current_version=$(read_env_var "$env_file" "VERSION")
    edition=$(read_env_var "$env_file" "EDITION")
    data_dir=$(read_env_var "$env_file" "DATA_DIR")
    db_name=$(read_env_var "$env_file" "DB_NAME")
    db_user=$(read_env_var "$env_file" "DB_USER")
    db_pass=$(read_env_var "$env_file" "DB_PASS")

    log_info "  Current version : ${current_version:-unknown}"
    log_info "  Target version  : $target_version"
    log_info "  Edition         : ${edition:-unknown}"
    log_info "  Data dir        : ${data_dir:-unknown}"

    # Skip if already on target version (unless --force)
    if [[ "$current_version" == "$target_version" ]] && [[ "$FORCE" != "true" ]]; then
        log_info "  Already on $target_version — skipping (use --force to override)"
        return 0
    fi

    # Check OAuth extensions on HOST VOLUME before container recreation.
    # We cannot rely on the container's /app path because it is ephemeral.
    local had_oauth=false
    local had_gtag=false
    local oauth_host_path="${data_dir}/${wiki_name}/extensions/PluggableAuth/extension.json"
    if [[ -f "$oauth_host_path" ]]; then
        had_oauth=true
        log_info "  OAuth extensions present on host — will reinstall after upgrade"
    else
        log_info "  OAuth extensions not found on host — will skip reinstall"
    fi

    local gtag_host_path="${data_dir}/${wiki_name}/extensions/GTag/extension.json"
    if [[ -f "$gtag_host_path" ]]; then
        had_gtag=true
        log_info "  GTag extension present on host — will reinstall after upgrade"
    else
        log_info "  GTag extension not found on host — will offer to install"
    fi

    local had_semantic=false
    local smw_host_path="${data_dir}/${wiki_name}/extensions/SemanticMediaWiki/extension.json"
    if [[ -f "$smw_host_path" ]]; then
        had_semantic=true
        log_info "  Semantic extensions present on host — will reinstall after upgrade"
    else
        log_info "  Semantic extensions not found on host — will skip"
    fi

    if [[ "$DRY_RUN" == "true" ]]; then
        log_info "  [DRY RUN] Steps that would execute:"
        log_info "    1.  Verify/add required env vars in compose file"
        log_info "    1b. Verify/generate INTERNAL_WIKI_* secrets"
        log_info "    1c. Verify/add tmpfs mounts in compose file"
        log_info "    2.  docker pull bluespice/wiki:${target_version}"
        log_info "    3.  Update .env (VERSION, BLUESPICE_WIKI_IMAGE)"
        log_info "    4.  Create preupdate/postupdate log directories"
        log_info "    5.  docker compose up -d --force-recreate"
        log_info "    6.  Wait for container + fix log dir ownership"
        log_info "    7.  php maintenance/run.php update --quick"
        [[ "$had_oauth"    == "true" ]] && log_info "    8.  install_auth_extensions"
        [[ "$had_semantic" == "true" ]] && log_info "    8b. install_semantic_extensions"
        log_info "    9.  Update wgCacheEpoch in post-init-settings.php"
        log_info "    10. Disable mwsgWireServiceWebsocketUrl in post-init-settings.php"
        log_info "    11. Enable parser cache (CACHE_MEMCACHED) in post-init-settings.php"
        [[ "$edition" == "free" ]] && log_info "    10. Check/fix PermissionManagerActivePreset"
        log_info "    13. Rebuild search index"
        return 0
    fi

    # --- Step 1: Ensure compose file has all required env vars ---
    log_info "  Verifying compose file env vars..."
    ensure_compose_env_var "$compose_file" "DATADIR"                      "/data/bluespice"
    ensure_compose_env_var "$compose_file" "WIKI_PRE_INIT_SETTINGS_FILE"  "/data/bluespice/pre-init-settings.php"
    ensure_compose_env_var "$compose_file" "WIKI_POST_INIT_SETTINGS_FILE" "/data/bluespice/post-init-settings.php"
    ensure_compose_env_var "$compose_file" "CACHE_HOST"                   "bluespice-cache"
    ensure_compose_env_var "$compose_file" "CACHE_PORT"                   "11211"
    ensure_compose_env_var "$compose_file" "DB_TYPE"                      "mysql"
    ensure_compose_env_var "$compose_file" "INTERNAL_WIRE_API_KEY"         "\${INTERNAL_WIRE_API_KEY}"

    # --- Step 1c: Ensure extension volume mounts exist ---
    log_info "  Verifying extension volume mounts..."
    ensure_compose_volume_mount "$compose_file" "${data_dir}/${wiki_name}/extensions/PluggableAuth" "/app/bluespice/w/extensions/PluggableAuth"
    ensure_compose_volume_mount "$compose_file" "${data_dir}/${wiki_name}/extensions/OpenIDConnect" "/app/bluespice/w/extensions/OpenIDConnect"
    ensure_compose_volume_mount "$compose_file" "${data_dir}/${wiki_name}/extensions/GTag"          "/app/bluespice/w/extensions/GTag"
    ensure_compose_volume_mount "$compose_file" "${data_dir}/${wiki_name}/extensions/SemanticMediaWiki"                "/app/bluespice/w/extensions/SemanticMediaWiki"
    ensure_compose_volume_mount "$compose_file" "${data_dir}/${wiki_name}/extensions/SemanticExtraSpecialProperties"  "/app/bluespice/w/extensions/SemanticExtraSpecialProperties"

    # --- Step 1d: Ensure tmpfs mounts are configured ---
    log_info "  Verifying tmpfs mounts..."
    ensure_compose_tmpfs "$compose_file" "/tmp/wiki:uid=1002,gid=1002" "wiki-web"
    ensure_compose_tmpfs "$compose_file" "/tmp/wiki:uid=1002,gid=1002" "wiki-task"

    # --- Step 1b: Ensure INTERNAL_WIKI_* secrets exist (required by 5.2.x) ---
    log_info "  Verifying INTERNAL_WIKI_* secrets..."
    for secret_var in INTERNAL_WIKI_SECRETKEY INTERNAL_WIKI_UPGRADEKEY INTERNAL_WIKI_TOKEN_AUTH_SALT INTERNAL_WIRE_API_KEY; do
        existing=$(read_env_var "$env_file" "$secret_var")
        if [[ -z "$existing" ]]; then
            new_secret=$(openssl rand -hex 32)
            echo "${secret_var}=${new_secret}" >> "$env_file"
            log_info "    Generated new ${secret_var}"
        fi
        ensure_compose_env_var "$compose_file" "$secret_var" "\${${secret_var}}"
    done

    # --- Step 2: Pull new image ---
    log_info "  Pulling bluespice/wiki:${target_version}..."
    if ! docker pull "bluespice/wiki:${target_version}"; then
        log_error "  Failed to pull bluespice/wiki:${target_version} — aborting upgrade for $wiki_name"
        return 1
    fi

    # --- Step 3: Update .env ---
    mkdir -p "$BACKUP_DIR"
    cp "$env_file" "${BACKUP_DIR}/${wiki_name}.env.bak"
    sed -i "s/^VERSION=.*/VERSION=${target_version}/" "$env_file"
    sed -i "s|^BLUESPICE_WIKI_IMAGE=.*|BLUESPICE_WIKI_IMAGE=bluespice/wiki:${target_version}|" "$env_file"
    # Ensure DB_TYPE, CACHE_HOST, CACHE_PORT are present in .env
    grep -q "^DB_TYPE=" "$env_file"    || echo "DB_TYPE=mysql"              >> "$env_file"
    grep -q "^CACHE_HOST=" "$env_file" || echo "CACHE_HOST=bluespice-cache" >> "$env_file"
    grep -q "^CACHE_PORT=" "$env_file" || echo "CACHE_PORT=11211"           >> "$env_file"
    log_info "  Updated .env to version $target_version"

    # --- Step 4: Pre-create run-updates log directories ---
    # If these don't exist before the container starts, run-updates fails trying to write logs.
    local log_base="${data_dir}/${wiki_name}/logs"
    mkdir -p "${log_base}/preupdate" "${log_base}/postupdate" 2>/dev/null || true
    log_info "  Ensured preupdate/postupdate log directories exist"

    local container_name
    container_name=$(get_container_name "$wiki_name")

    # --- Step 5: Recreate containers ---
    log_info "  Recreating containers with new image..."
    cd "$wiki_dir" || return 1
    if ! docker compose --env-file .env -f docker-compose.main.yml up -d --force-recreate; then
        log_error "  docker compose up failed for $wiki_name"
        return 1
    fi

    # --- Step 6: Wait for container and fix log dir ownership ---
    log_info "  Waiting for wiki-web container to be ready..."
    if ! wait_for_container_ready "$wiki_name" 120; then
        log_error "  Container did not become ready within 120s for $wiki_name"
        return 1
    fi
    # Fix ownership so run-updates can write to the log directories
    docker exec --user root "$container_name" \
        chown 1002:bluespice \
        /data/bluespice/logs/preupdate \
        /data/bluespice/logs/postupdate 2>/dev/null || true
    # Ensure settings files are group-writable (664) so the host upgrade
    # script (running as a bluespice group member) can modify them.
    docker exec "$container_name" chmod 664 \
        /data/bluespice/pre-init-settings.php \
        /data/bluespice/post-init-settings.php 2>/dev/null || true

    # --- Step 7a: Clean up broken ContentProvisioner blob data ---
    # After a version upgrade the ContentProvisioner re-runs and may encounter orphaned
    # blob references left from a previous partial run (e.g. Template:CircledNumber with
    # a <templatestyles> subpage that wasn't created yet). Delete the stale data and
    # reset the ContentProvisioner updatelog entry so it runs cleanly.
    log_info "  Cleaning up broken ContentProvisioner data before update..."
    if [[ -n "$db_name" && -n "$db_user" && -n "$db_pass" ]]; then
        docker exec bluespice-database mariadb -u "$db_user" -p"$db_pass" "$db_name" -e "
            DELETE s FROM slots s
                LEFT JOIN text t ON CAST(SUBSTRING(
                    (SELECT c.content_address FROM content c WHERE c.content_id = s.slot_content_id),
                    4) AS UNSIGNED) = t.old_id
                WHERE (SELECT c.content_address FROM content c WHERE c.content_id = s.slot_content_id) LIKE 'tt:%'
                AND t.old_id IS NULL;
            DELETE c FROM content c
                LEFT JOIN slots s ON s.slot_content_id = c.content_id
                WHERE s.slot_content_id IS NULL;
            DELETE r FROM revision r
                LEFT JOIN slots s ON s.slot_revision_id = r.rev_id
                WHERE s.slot_revision_id IS NULL AND r.rev_id > 1;
            DELETE p FROM page p
                LEFT JOIN revision r ON r.rev_page = p.page_id
                WHERE r.rev_id IS NULL;
            DELETE FROM updatelog WHERE ul_key LIKE '%ContentProvisioner%ProvisionContents%';
        " 2>/dev/null || log_warn "  Blob cleanup query had errors (non-fatal)"
        log_info "  Blob cleanup complete"
    else
        log_warn "  Skipping blob cleanup — DB credentials not available"
    fi

    # --- Step 7b: Run MediaWiki database update ---
    log_info "  Running MediaWiki database update..."
    if docker exec --user root "$container_name" \
        php /app/bluespice/w/maintenance/run.php update --quick; then
        log_info "  Database update completed successfully"
    else
        log_warn "  update.php exited non-zero (may be non-fatal — continuing)"
    fi

    # --- Step 8: Reinstall OAuth extensions if previously present ---
    if [[ "$had_oauth" == "true" ]]; then
        log_info "  Reinstalling OAuth extensions..."
        if install_auth_extensions "$wiki_name"; then
            log_info "  OAuth extensions reinstalled successfully"
        else
            log_warn "  OAuth extension reinstall failed — wiki is functional but OAuth login may not work"
        fi
    fi

    # --- Step 8b: Install or reinstall GTag extension ---
    local post_init_file="${data_dir}/${wiki_name}/post-init-settings.php"
    if [[ "$had_gtag" == "true" ]]; then
        log_info "  Reinstalling GTag extension..."
        if install_gtag_extension "$wiki_name"; then
            log_info "  GTag extension reinstalled successfully"
        else
            log_warn "  GTag extension reinstall failed — Google Analytics tracking may not work"
        fi
    else
        echo ""
        echo "  Wiki: ${wiki_name}"
        printf "  Install Google Analytics (GTag) extension for this wiki? [y/N]: "
        read -r install_gtag_answer
        if [[ "$install_gtag_answer" =~ ^[Yy]$ ]]; then
            log_info "  Installing GTag extension for ${wiki_name}..."
            if setup_gtag_extension "$wiki_name" "$post_init_file"; then
                log_info "  GTag extension installed and configured successfully"
            else
                log_warn "  GTag extension setup failed — you can install it manually later"
            fi
        else
            log_info "  Skipping GTag extension for ${wiki_name}"
        fi
    fi

    # --- Step 8c: Reinstall or install Semantic extensions ---
    # Pass $post_init_file (the data-volume path) so the wfLoadExtension block is
    # written to the live copy that the container reads, not the config-dir copy.
    local wiki_dir_local="${WIKIS_DIR}/${wiki_name}"
    if [[ "$had_semantic" == "true" ]]; then
        log_info "  Reinstalling Semantic extensions..."
        if setup_semantic_extensions "$wiki_name" "$wiki_dir_local" "$post_init_file"; then
            log_info "  Semantic extensions reinstalled successfully"
        else
            log_warn "  Semantic extension reinstall failed — SemanticMediaWiki may not work"
        fi
    else
        echo ""
        echo "  Wiki: ${wiki_name}"
        printf "  Install SemanticMediaWiki and SemanticExtraSpecialProperties extensions? [y/N]: "
        read -r install_smw_answer
        if [[ "$install_smw_answer" =~ ^[Yy]$ ]]; then
            log_info "  Installing Semantic extensions for ${wiki_name}..."
            if setup_semantic_extensions "$wiki_name" "$wiki_dir_local" "$post_init_file"; then
                log_info "  Semantic extensions installed and configured successfully"
            else
                log_warn "  Semantic extension setup failed — you can install it manually later"
            fi
        else
            log_info "  Skipping Semantic extensions for ${wiki_name}"
        fi
    fi

    # --- Step 9: Bump wgCacheEpoch ---
    update_cache_epoch "$wiki_name" "$post_init_file"
    # --- Step 10: Enable wire WebSocket URL (wire container now deployed) ---
    enable_wire_websocket_url "$wiki_name" "$post_init_file"

    # --- Step 11: Enable parser cache ---
    fix_parser_cache "$wiki_name" "$post_init_file"

    # --- Step 12: Fix PermissionManagerActivePreset for Free edition ---
    if [[ "$edition" == "free" ]] && [[ -n "$db_name" ]]; then
        fix_permission_manager_preset "$db_name" "$db_user" "$db_pass"
    fi

    # --- Step 13: Rebuild search index ---
    # New BlueSpice versions may add index fields (e.g. suggestions-spellcheck) that
    # require a full rebuild to create the updated mapping. Without this, searches
    # throw BadRequest400Exception and show "Query cannot be executed" in the UI.
    log_info "  Rebuilding search index with updated mappings..."
    local rebuild_output rebuild_ok=false
    if rebuild_output=$(docker exec "$container_name" /app/bin/rebuild-searchindex --main 2>&1); then
        rebuild_ok=true
    fi
    echo "$rebuild_output" | grep -E "done:|created:|Error" | head -10 || true
    if [[ "$rebuild_ok" == "true" ]]; then
        log_info "  Search index rebuilt"
    else
        log_warn "  Search index rebuild may have had issues — search could be degraded"
    fi

    log_info "  $wiki_name upgraded to $target_version successfully"
    return 0
}

# ============================================================
# Shared services upgrade
# ============================================================
upgrade_shared_services() {
    local target_version="$1"
    local shared_env="${SHARED_DIR}/.shared.env"

    log_info ""
    log_info "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    log_info "Shared services → $target_version"
    log_info "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

    if [[ ! -f "$shared_env" ]]; then
        log_warn "Shared env not found at $shared_env — skipping shared services upgrade"
        return 0
    fi

    if [[ "$DRY_RUN" == "true" ]]; then
        log_info "  [DRY RUN] Would update $shared_env VERSION=$target_version and restart services"
        return 0
    fi

    mkdir -p "$BACKUP_DIR"
    cp "$shared_env" "${BACKUP_DIR}/shared.env.bak"
    sed -i "s/^VERSION=.*/VERSION=${target_version}/" "$shared_env"
    log_info "  Updated shared .env to version $target_version"

    cd "$SHARED_DIR" || return 1

    # Ensure VERSION and BLUESPICE_SERVICE_REPOSITORY are available to docker compose
    export VERSION="$target_version"
    export BLUESPICE_SERVICE_REPOSITORY="${BLUESPICE_SERVICE_REPOSITORY:-bluespice}"

    log_info "  Restarting persistent data services..."
    if docker compose --env-file .shared.env \
        -f docker-compose.persistent-data-services.yml up -d; then
        log_info "  Persistent data services restarted"
    else
        log_warn "  Persistent data services restart had errors (non-fatal if already running)"
    fi

    # Brief pause for DB to stabilise before restarting stateless services
    sleep 5

    log_info "  Restarting stateless and proxy services..."
    if docker compose --env-file .shared.env \
        -f docker-compose.stateless-services.yml \
        -f docker-compose.proxy.yml \
        -f docker-compose.proxy-letsencrypt.yml \
        up -d; then
        log_info "  Stateless/proxy services restarted"
    else
        log_warn "  Some stateless/proxy services may not have started (non-fatal)"
    fi
}

# ============================================================
# Main
# ============================================================
main() {
    # Auto-detect target version if not specified
    if [[ -z "$TARGET_VERSION" ]]; then
        log_info "No --version specified. Detecting latest BlueSpice version from Docker Hub..."
        if ! TARGET_VERSION=$(detect_latest_version); then
            log_error "Could not detect latest version. Please specify with --version VERSION"
            exit 1
        fi
        log_info "Detected latest BlueSpice version: $TARGET_VERSION"
    fi

    log_info ""
    log_info "═══════════════════════════════════════════════════"
    log_info "BlueSpice Upgrade  →  $TARGET_VERSION"
    [[ "$DRY_RUN" == "true" ]] && log_info "Mode: DRY RUN (no changes will be made)"
    [[ "$FORCE"   == "true" ]] && log_info "Mode: FORCE (will re-upgrade wikis already on target)"
    [[ -n "$SPECIFIC_WIKI" ]] && log_info "Scope: wiki '$SPECIFIC_WIKI' only"
    log_info "Backups: $BACKUP_DIR"
    log_info "═══════════════════════════════════════════════════"

    # Upgrade shared services before wikis (DB must be up for update.php)
    if [[ "$SKIP_SHARED" != "true" ]]; then
        upgrade_shared_services "$TARGET_VERSION"
    else
        log_info "Skipping shared services (--skip-shared)"
    fi

    # Build wiki list
    local wiki_list=()
    if [[ -n "$SPECIFIC_WIKI" ]]; then
        wiki_list=("$SPECIFIC_WIKI")
    else
        for wiki_dir in "${WIKIS_DIR}"/*/; do
            if [[ -d "$wiki_dir" ]] && [[ -f "${wiki_dir}/.env" ]]; then
                wiki_list+=("$(basename "$wiki_dir")")
            fi
        done
    fi

    if [[ ${#wiki_list[@]} -eq 0 ]]; then
        log_warn "No wikis found in $WIKIS_DIR"
        exit 0
    fi

    log_info ""
    log_info "Found ${#wiki_list[@]} wiki(s): ${wiki_list[*]}"

    local success_count=0
    local fail_count=0
    local failed_wikis=()

    for wiki_name in "${wiki_list[@]}"; do
        if upgrade_wiki "$wiki_name" "$TARGET_VERSION"; then
            success_count=$((success_count + 1))
        else
            fail_count=$((fail_count + 1))
            failed_wikis+=("$wiki_name")
        fi
    done

    # Update the canonical version file if any wikis succeeded
    if [[ $success_count -gt 0 && "$DRY_RUN" != "true" ]]; then
        echo "$TARGET_VERSION" > "${SCRIPT_DIR}/BLUESPICE_VERSION"
        log_info "Updated BLUESPICE_VERSION to $TARGET_VERSION"
    fi

    log_info ""
    log_info "═══════════════════════════════════════════════════"
    log_info "Upgrade Summary"
    log_info "  Succeeded : $success_count"
    if [[ $fail_count -gt 0 ]]; then
        log_error "  Failed    : $fail_count  (${failed_wikis[*]})"
        log_info  "  Restore   : cp ${BACKUP_DIR}/WIKI_NAME.env.bak ${WIKIS_DIR}/WIKI_NAME/.env"
    fi
    log_info "  Backups   : $BACKUP_DIR"
    log_info "═══════════════════════════════════════════════════"

    if [[ $fail_count -gt 0 ]]; then
        exit 1
    fi
}

main
