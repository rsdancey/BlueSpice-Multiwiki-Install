# Main execution with improved validation and error handling
main() {
    # Parse command line arguments
    parse_arguments "$@"

    # Check upstream bluespice-deploy for new services before proceeding
    local target_version
    target_version=$("${SCRIPT_DIR}/lib/get-latest-bluespice-version.sh" 2>/dev/null) || target_version=""
    if [[ -n "$target_version" ]]; then
        if ! check_upstream_services "$target_version"; then
            log_error "Please update core_install to support the new services before creating a wiki."
            exit 1
        fi
    fi

    echo "🚀 BlueSpice Wiki Initialization Wizard"
    echo "========================================"
    echo
    
    # Get wiki name with proper validation
    while [[ -z "$WIKI_NAME" ]]; do
        printf "Enter wiki name (alphanumeric, dots, dashes, underscores, no spaces): "
        read -r WIKI_NAME
        
        if ! validate_wiki_name "$WIKI_NAME"; then
            WIKI_NAME=""
            continue
        fi
        
        # Check for existing directory
        if [[ -d "${WIKIS_DIR}/${WIKI_NAME}" ]]; then
            echo
            log_warn "Wiki directory '${WIKIS_DIR}/${WIKI_NAME}' already exists"
            echo "This may contain data from a previous installation."
            echo
            printf "Remove existing directory and continue? [y/N]: "
            read -r confirm
            
            if [[ "$confirm" =~ ^[Yy]$ ]]; then
                log_info "Removing existing directory..."
                if rm -rf "${WIKIS_DIR:?}/${WIKI_NAME:?}"; then
                    log_info "Existing directory removed"
                else
                    log_error "Failed to remove existing directory"
                    exit 1
                fi
            else
                log_info "Using existing directory - continuing with current setup..."
                SKIP_DIRECTORY_SETUP=true
            fi
        fi
    done
    
    # Collect configuration if not using existing directory
    if [[ "$SKIP_DIRECTORY_SETUP" != "true" ]]; then
        # Get wiki domain
        while [[ -z "$WIKI_DOMAIN" ]]; do
            printf "Enter wiki domain (e.g., wiki.example.com): "
            read -r WIKI_DOMAIN
            validate_domain "$WIKI_DOMAIN" || WIKI_DOMAIN=""
        done
        
        # Get wiki language
        echo "Available languages: en, de, fr, es, it, pt, nl, pl, ru, ja, zh"
        printf "Enter wiki language code [en]: "
        read -r WIKI_LANG
        WIKI_LANG="${WIKI_LANG:-en}"
        validate_language_code "$WIKI_LANG" || WIKI_LANG="en"
        
        # Get SMTP configuration
        echo
        echo "📧 SMTP Configuration:"
        echo "Configure email settings for wiki notifications"
        echo
        
        # SMTP Host
        while [[ -z "$SMTP_HOST" ]]; do
            printf "Enter SMTP host: "
            read -r SMTP_HOST
            validate_smtp_host "$SMTP_HOST" || SMTP_HOST=""
        done
        
        # SMTP Port
        printf "Enter SMTP port [587]: "
        read -r SMTP_PORT
        SMTP_PORT="${SMTP_PORT:-587}"
        validate_port "$SMTP_PORT" "SMTP port" || SMTP_PORT="587"
        
        # SMTP Username (email)
        while [[ -z "$SMTP_USER" ]]; do
            printf "Enter SMTP username (email address): "
            read -r SMTP_USER
            validate_email "$SMTP_USER" || SMTP_USER=""
        done
        
        # SMTP Password
        while [[ -z "$SMTP_PASS" ]]; do
            printf "Enter SMTP password: "
            read -r SMTP_PASS
            validate_smtp_pass "$SMTP_PASS" || SMTP_PASS=""
        done

        # Google Analytics GTag
        echo ""
        printf "Install Google Analytics (GTag) extension? [y/N]: "
        read -r install_gtag_choice
        if [[ "$install_gtag_choice" =~ ^[Yy]$ ]]; then
            echo ""
            echo "📊 Google Analytics Configuration:"
            echo "Configure Google Analytics tracking for your wiki"
            echo ""
            prompt_gtag_analytics_id
        else
            GTAG_ANALYTICS_ID=""
            log_info "Skipping GTag extension"
        fi
        
    else
        log_info "Loading existing configuration..."
        # Load existing configuration from .env file
        local env_file="${WIKIS_DIR}/${WIKI_NAME}/.env"
        if [[ -f "$env_file" ]]; then
            # Source the environment file safely
            # shellcheck disable=SC1090
            source "$env_file" 2>/dev/null || true
            WIKI_DOMAIN="${WIKI_HOST:-}"
            WIKI_LANG="${WIKI_LANG:-en}"
            SMTP_HOST="${SMTP_HOST:-}"
            SMTP_PORT="${SMTP_PORT:-587}"
            SMTP_USER="${SMTP_USER:-}"
            
            log_info "Loaded existing configuration from $env_file"
        else
            log_warn "No .env file found in existing directory"
            log_warn "You will need to configure the wiki manually"
        fi
    fi
    
    # Get setup mode
    echo
    echo "Setup options:"
    echo "1) New wiki with SSL certificate"
    echo "2) New wiki without SSL (HTTP only)"
    echo "3) Restore from backup"
    echo "4) Restore from backup with images"
    
    local choice=""
    while [[ ! "$choice" =~ ^[1-4]$ ]]; do
        printf "Choose option [1/2/3/4]: "
        read -r choice
        if [[ ! "$choice" =~ ^[1-4]$ ]]; then
            echo "❌ Please enter 1, 2, 3, or 4"
        fi
    done
    
    case $choice in
        1)
            SETUP_MODE="ssl"
            SSL_ENABLED=true
            log_info "Selected: New wiki with SSL certificate"
            ;;
        2)
            SETUP_MODE="new"
            SSL_ENABLED=false
            log_info "Selected: New wiki without SSL"
            ;;
        3)
            SETUP_MODE="restore"
            SSL_ENABLED=false
            printf "Enter path to backup file (.sql): "
            read -r BACKUP_FILE
            while [[ -z "$BACKUP_FILE" ]] || ! validate_file_exists "$BACKUP_FILE" "Backup file"; do
                printf "Enter path to backup file (.sql): "
                read -r BACKUP_FILE
            done
            log_info "Selected backup file: $BACKUP_FILE"
            ;;
        4)
            SETUP_MODE="restore_with_images"
            SSL_ENABLED=false
            printf "Enter path to backup file (.sql): "
            read -r BACKUP_FILE
            while [[ -z "$BACKUP_FILE" ]] || ! validate_file_exists "$BACKUP_FILE" "Backup file"; do
                printf "Enter path to backup file (.sql): "
                read -r BACKUP_FILE
            done
            printf "Enter path to images archive (.zip): "
            read -r IMAGES_FILE
            while [[ -z "$IMAGES_FILE" ]] || ! validate_file_exists "$IMAGES_FILE" "Images file"; do
                printf "Enter path to images archive (.zip): "
                read -r IMAGES_FILE
            done
            log_info "Selected backup file: $BACKUP_FILE"
            log_info "Selected images file: $IMAGES_FILE"
            ;;
    esac
    
    # Apply default values and validate configuration
    apply_defaults
    
    # Validate all configuration
    if ! validate_configuration; then
        log_error "Configuration validation failed"
        return 1
    fi
    
    # Show configuration summary and get confirmation
    if ! confirm_configuration; then
        log_info "Setup cancelled by user"
        exit
    fi
    
    echo
    log_info "Starting wiki initialization..."
    
    # Setup process with improved error handling
    if [[ "$SKIP_DIRECTORY_SETUP" != "true" ]]; then
        if ! setup_wiki_directory; then
            log_error "Failed to setup wiki directory"
            return 1
        fi
        
        if ! create_environment_file; then
            log_error "Failed to create environment file"
            return 1
        fi
    else
        log_info "Using existing directory - skipping directory and environment setup"
    fi

    load_environment "${WIKIS_DIR}/${WIKI_NAME}"

    # create the init-settings files
    if ! create-init-settings-config-files "${WIKIS_DIR}/${WIKI_NAME}" "$WIKI_NAME"; then
        log_error "Failed to create init-settings files"
        exit 1
    fi
    
    # Deploy wiki
    if ! deploy_wiki_instance; then
        log_error "Wiki deployment failed"
        exit 1
    fi
    
    # Copy configuration files to the running container
    log_info "Copying configuration files to container..."
    if ! copy_config_files_to_container "$WIKI_NAME" "${WIKIS_DIR}/${WIKI_NAME}"; then
        log_error "Writing configuration files to container failed"
        exit 1
    fi

    # Install per-wiki logrotate configuration on host
    if command -v create_wiki_logrotate_config >/dev/null 2>&1; then
        if ! create_wiki_logrotate_config "$WIKI_NAME" "${DATA_DIR}"; then
            log_warn "Per-wiki logrotate config not installed automatically; you can install it later."
        fi
    else
        log_warn "Logrotate helper not available; skipping per-wiki logrotate configuration."
    fi

    # Handle backup restoration if selected
    if [[ "$SETUP_MODE" == "restore" ]]; then
        if ! restore_from_backup "$BACKUP_FILE"; then
            log_error "Backup restoration failed"
            exit 1
        fi
    elif [[ "$SETUP_MODE" == "restore_with_images" ]]; then
        if ! restore_from_backup "$BACKUP_FILE"; then
            log_error "Backup restoration failed"
            exit 1
        fi
        if ! "${SCRIPT_DIR}/import-images.sh" --wiki-name="$WIKI_NAME" --images-archive="$IMAGES_FILE"; then
            log_error "Images import failed"
            exit 1
        fi
    fi

    # The initial run-installation includes update.php which runs the ContentProvisioner.
    # Template:CircledNumber contains <templatestyles> referencing a styles.css subpage.
    # The first ContentProvisioner run partially creates this page but the TemplateStyles
    # hook fails (broken blob), leaving orphaned revision data. Clean up the broken data
    # and reset the ContentProvisioner log entry so it can run cleanly on the second pass.
    log_info "Cleaning up broken ContentProvisioner data from initial install..."
    local _db_name _db_user _db_pass
    _db_name=$(grep '^DB_NAME=' "${WIKIS_DIR}/${WIKI_NAME}/.env" | cut -d= -f2-)
    _db_user=$(grep '^DB_USER=' "${WIKIS_DIR}/${WIKI_NAME}/.env" | cut -d= -f2-)
    _db_pass=$(grep '^DB_PASS=' "${WIKIS_DIR}/${WIKI_NAME}/.env" | cut -d= -f2-)
    if [[ -n "$_db_name" && -n "$_db_user" && -n "$_db_pass" ]]; then
        # Delete orphaned slots/content/revisions that reference missing text blobs
        docker exec bluespice-database mariadb -u "$_db_user" -p"$_db_pass" "$_db_name" -e "
            DELETE s FROM slots s
                LEFT JOIN text t ON CAST(SUBSTRING(
                    (SELECT c.content_address FROM content c WHERE c.content_id = s.slot_content_id),
                    4) AS UNSIGNED) = t.old_id
                WHERE (SELECT c.content_address FROM content c WHERE c.content_id = s.slot_content_id) LIKE 'tt:%'
                AND t.old_id IS NULL;
            DELETE c FROM content c
                LEFT JOIN slots s ON s.slot_content_id = c.content_id
                WHERE s.slot_content_id IS NULL;
            DELETE r FROM revision r
                LEFT JOIN slots s ON s.slot_revision_id = r.rev_id
                WHERE s.slot_revision_id IS NULL AND r.rev_id > 1;
            DELETE p FROM page p
                LEFT JOIN revision r ON r.rev_page = p.page_id
                WHERE r.rev_id IS NULL;
            DELETE FROM updatelog WHERE ul_key LIKE '%ContentProvisioner%ProvisionContents%';
        " 2>/dev/null || log_warn "  Blob cleanup query had errors (non-fatal)"
        log_info "  Cleanup complete"
    fi

    docker_exec_safe "$WIKI_NAME" "/app/bin/run-maintenance update.php --quick --doshared" || true

    # Rebuild search index
    echo
    if ! rebuild_search_index "$WIKI_NAME"; then
        log_warn "Search index rebuild failed - search may not work properly"
        log_warn "You can manually rebuild it later with:"
        log_warn "  docker exec --user root bluespice-${WIKI_NAME}-wiki-web sh -lc 'cd /app/bluespice/w && php extensions/BlueSpiceExtendedSearch/maintenance/rebuildIndex.php && php maintenance/runJobs.php'"
    fi
    echo
    setup_ssl
    
    # Show completion information
    show_completion_info
    exit 0
}

# Run main function if script is executed directly
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi
