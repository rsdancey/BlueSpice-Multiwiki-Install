#!/bin/bash

# BlueSpice Shared Services Setup Script
# Simple, clean setup that uses native Docker Compose

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Directory paths
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SHARED_DIR="${SCRIPT_DIR}/shared"
SHARED_ENV="${SHARED_DIR}/.shared.env"

echo -e "${BLUE}BlueSpice Shared Services Setup${NC}"
echo -e "${BLUE}===============================${NC}"
echo

# Ensure the shared services directory exists
if [[ ! -d "$SHARED_DIR" ]]; then
    echo -e "${RED}❌ Error: Shared services directory not found: $SHARED_DIR${NC}" >&2
    exit 1
fi

# Handle email configuration
if [[ -f "$SHARED_ENV" ]]; then
    # shellcheck source=/dev/null
    source "$SHARED_ENV"
    CURRENT_EMAIL="${ADMIN_MAIL:-somuser@somedomain.tld}"
else
    CURRENT_EMAIL="somuser@somedomain.tld"
fi

read -r -p "Enter email address for Let's Encrypt (press Enter to use existing: $CURRENT_EMAIL): " NEW_EMAIL
ADMIN_MAIL=${NEW_EMAIL:-$CURRENT_EMAIL}

echo "Using admin mail: $ADMIN_MAIL"

# Ensure DATA_DIR is set
CURRENT_DATA_DIR="${DATA_DIR:-/bluespice}"
read -r -p "Enter data directory (press Enter to use existing: $CURRENT_DATA_DIR): " NEW_DATA_DIR
DATA_DIR="${NEW_DATA_DIR:-$CURRENT_DATA_DIR}"
echo "Using data directory: $DATA_DIR"

# Ensure DB_ROOT_PASS is set
if [[ -z "${DB_ROOT_PASS:-}" ]]; then
    DB_ROOT_PASS="$(openssl rand -base64 24 | tr -d '/+=' | head -c 32)"
    echo "Generated new database root password."
fi

# Ensure a host-side directory exists with correct group and permissions
ensure_host_dir_permissions() {
    local path="$1"
    if [[ ! -d "$path" ]]; then
        sudo mkdir -p "$path" 2>/dev/null || mkdir -p "$path"
    fi
    sudo chgrp -R bluespice "$path" 2>/dev/null || true
    sudo chmod -R g+rwX "$path" 2>/dev/null || true
    sudo find "$path" -type d -exec chmod g+s {} + 2>/dev/null || true
}

# Pre-create shared data directories with correct perms to avoid root-only Docker-created paths
prepare_shared_data_dirs() {
    # DATA_DIR may be present from .shared.env; default conservatively to /bluespice
    local base_dir="${DATA_DIR:-/bluespice}"
    local dirs=(
        "$base_dir"
        "$base_dir/proxy/vhost.d"
        "$base_dir/proxy/html"
        "$base_dir/proxy/certs"
        "$base_dir/proxy/conf.d"
        "$base_dir/letsencrypt"
        "$base_dir/search"
        "$base_dir/database/data"
        "$base_dir/database/logs"
    )
    for d in "${dirs[@]}"; do
        ensure_host_dir_permissions "$d"
    done
}

# Ensure shared data directories exist with correct permissions
prepare_shared_data_dirs

# Update environment file if needed
update_or_append_env() {
    local key="$1"
    local value="$2"
    if grep -q "^${key}=" "$SHARED_ENV" 2>/dev/null; then
        sed -i "s|^${key}=.*|${key}=${value}|" "$SHARED_ENV"
    else
        echo "${key}=${value}" >> "$SHARED_ENV"
    fi
}

update_or_append_env "ADMIN_MAIL" "$ADMIN_MAIL"
update_or_append_env "DATA_DIR" "$DATA_DIR"
update_or_append_env "DB_ROOT_PASS" "$DB_ROOT_PASS"

echo -e "${GREEN}✓ Environment configuration updated${NC}"
echo

# Change to shared directory and start services
cd "$SHARED_DIR"

# Initialize database with network permissions
initialize_database() {
    echo -e "${BLUE}Initializing database permissions...${NC}"
    
    # Wait for database to be ready
    local max_attempts=30
    local attempt=1
    
    while [[ $attempt -le $max_attempts ]]; do
        if docker ps --filter name=bluespice-database --filter health=healthy --format "{{.Names}}" | grep -q bluespice-database; then
            echo -e "${GREEN}✓ Database is healthy${NC}"
            break
        elif [[ $attempt -eq $max_attempts ]]; then
            echo -e "${RED}❌ Database failed to become healthy${NC}"
            return 1
        else
            echo "⏳ Waiting for database to be healthy (attempt $attempt/$max_attempts)..."
            sleep 2
            ((attempt++))
        fi
    done
    
    # Source shared environment for root password
    if [[ -f "$SHARED_ENV" ]]; then
    # shellcheck source=/dev/null
        source "$SHARED_ENV"
    else
        echo -e "${RED}❌ Shared environment file not found${NC}"
        return 1
    fi
    
    # Initialize root user passwords for all hosts
    echo "Setting up root user passwords for all hosts..."
    if docker exec bluespice-database mariadb -u root -e "
-- Set password for all existing root users
SET PASSWORD FOR 'root'@'localhost' = '$DB_ROOT_PASS';
SET PASSWORD FOR 'root'@'127.0.0.1' = '$DB_ROOT_PASS';
SET PASSWORD FOR 'root'@'::1' = '$DB_ROOT_PASS';
-- Update any other root users to have the password
ALTER USER IF EXISTS 'root'@'localhost' IDENTIFIED BY '$DB_ROOT_PASS';
ALTER USER IF EXISTS 'root'@'127.0.0.1' IDENTIFIED BY '$DB_ROOT_PASS';
ALTER USER IF EXISTS 'root'@'::1' IDENTIFIED BY '$DB_ROOT_PASS';
-- Create/update network root users
CREATE USER IF NOT EXISTS 'root'@'%.bluespice-network' IDENTIFIED BY '$DB_ROOT_PASS';
GRANT ALL PRIVILEGES ON *.* TO 'root'@'%.bluespice-network' WITH GRANT OPTION;
FLUSH PRIVILEGES;" 2>/dev/null; then
        echo -e "${GREEN}✓ Database network permissions configured${NC}"
    
        return 0
    else
        echo -e "${YELLOW}⚠ Database permissions may already be configured${NC}"
        return 0
    fi
}

# Use the shared services management script for consistency
# Start shared services first
echo "Starting shared services..."
"${SCRIPT_DIR}/bluespice-shared-services" up -d

# Check if database initialization is needed
if docker ps --filter name=bluespice-database --format "{{.Names}}" | grep -q bluespice-database; then
    # Wait a moment for database to start
    sleep 3
    initialize_database
else
    echo -e "${YELLOW}⚠ Database container not found - skipping initialization${NC}"
fi

echo -e "${GREEN}✓ Shared services setup complete${NC}"
echo "Services are starting in the background."
echo "Use './bluespice-shared-services status' to check service health."
exit 0

